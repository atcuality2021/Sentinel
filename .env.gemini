# ── Config A: CLOUD (Gemini) ────────────────────────────────────────────────
# Managed Gemini for both grounding and reasoning. Fastest path; needs an AI Studio key.
# Use: cp .env.gemini .env   (then fill GOOGLE_API_KEY)
SENTINEL_LLM_BACKEND=gemini

GOOGLE_API_KEY=
GOOGLE_GENAI_USE_VERTEXAI=FALSE
SENTINEL_GEMINI_MODEL=gemini-2.5-flash
