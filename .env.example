# ── Sentinel configuration ─────────────────────────────────────────────────
# Copy to `.env` (gitignored).
#
# ONE rule — no split-brain config:
#   • SECRETS (API keys)      → here, in .env.            (read fresh every run)
#   • EVERYTHING ELSE         → Settings UI → sentinel.config.yaml.
#       models · endpoints · default backend · prompts · generation · memory
#   Open http://localhost:8080/settings to change anything that isn't a secret.

# ── Secrets — the ONLY runtime-authoritative values in this file ─────────────
# Gemini / AI Studio key. Needed for public web grounding (google_search) in
# BOTH backends — grounding stays Gemini-native even when reasoning runs on vLLM.
# Get one at https://aistudio.google.com/apikey
GOOGLE_API_KEY=
# AI Studio (FALSE) vs Vertex AI (TRUE). ADK reads this.
GOOGLE_GENAI_USE_VERTEXAI=FALSE
# Bearer token for your on-prem / hosted OpenAI-compatible reasoning server (vLLM,
# llama.cpp, TGI, a hosted Gemma, …). Leave "not-needed" only if it is unauthenticated.
VLLM_API_KEY=not-needed

# ── First-boot seed (OPTIONAL, headless only) ────────────────────────────────
# These seed sentinel.config.yaml ONLY when it does not yet exist (e.g. a fresh
# Cloud Run container with no UI). Once the file exists the Settings UI is
# authoritative and these are ignored — so for interactive use leave them commented
# and set the model / endpoint / default in the UI instead.
# SENTINEL_LLM_BACKEND=gemini
# SENTINEL_GEMINI_MODEL=gemini-2.5-flash
# VLLM_MODEL=gemma-4-12B
# VLLM_API_BASE=https://gemma.atcuality.com/v1

# ── Private boundary (Workspace MCP connector) ──────────────────────────────
# Leave unset to run public-only (client mode degrades gracefully with a flagged gap).
# SENTINEL_MCP_TRANSPORT=stdio
# SENTINEL_MCP_COMMAND=npx
# SENTINEL_MCP_ARGS=-y @some/workspace-mcp-server
# SENTINEL_MCP_URL=https://your-mcp-host/mcp
# SENTINEL_MCP_TOOL_FILTER=search_documents,get_document,list_calendar_events

# Optional: path to the runtime config file (default ./sentinel.config.yaml)
# SENTINEL_CONFIG_PATH=sentinel.config.yaml

# --- SENTINEL-005: Pluggable public search (provider chosen in Settings → Search) ----------
# Secrets only. The provider/results/fallback themselves live in sentinel.config.yaml (one center).
# DuckDuckGo is keyless. Brave & SerpAPI need a key (shown in Settings as a set/not-set pill):
# BRAVE_API_KEY=
# SERPAPI_API_KEY=
# First-boot seed for the default provider (ignored once sentinel.config.yaml exists):
# SENTINEL_SEARCH_PROVIDER=gemini
