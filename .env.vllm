# ── Config B: ON-PREM (Gemma on vLLM) ───────────────────────────────────────
# Reasoning (planner, synthesis, private-data analysis) runs on a LOCAL Gemma served by
# vLLM — nothing confidential leaves your hardware. Start the server first:
#     HF_TOKEN=hf_... docker compose -f deploy/vllm-compose.yml up
# Use: cp .env.vllm .env   (then fill GOOGLE_API_KEY for public grounding)
SENTINEL_LLM_BACKEND=vllm

# Local vLLM (OpenAI-compatible). Change VLLM_MODEL to whatever tag you served.
VLLM_API_BASE=http://localhost:8000/v1
VLLM_MODEL=google/gemma-3-4b-it
VLLM_API_KEY=not-needed

# Public web grounding stays Gemini-native (it is public data). Still needs a key.
# Omit this only if you run client mode with NO public research (fully air-gapped).
GOOGLE_API_KEY=
GOOGLE_GENAI_USE_VERTEXAI=FALSE
SENTINEL_GEMINI_MODEL=gemini-2.5-flash
